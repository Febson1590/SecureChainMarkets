# ─── SecureChainMarkets — Environment Configuration ─────────────────
# Copy to `.env` and fill in real values. All secrets must be kept
# out of source control — `.env` is git-ignored.

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Provision a fresh empty Postgres database for this project. The app
# starts with zero rows in every user/transaction/session table; only
# market-asset reference rows are populated when you run `db:seed`.
#   Local dev example:  postgresql://postgres:postgres@localhost:5432/securechainmarkets
#   Hosted example:     postgresql://user:password@host:5432/securechainmarkets?sslmode=require
DATABASE_URL=

# ── Auth.js / NextAuth ──────────────────────────────────────────────
# Generate a fresh secret per environment:
#   openssl rand -base64 32
AUTH_SECRET=
# Public origin used by the auth flow and absolute-URL email links.
NEXTAUTH_URL=http://localhost:3000

# ── Public app URL ──────────────────────────────────────────────────
# Used for absolute URLs in emails, OG metadata, and notifications.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Transactional email (Resend) ────────────────────────────────────
# Leave blank to disable email sending in dev.
RESEND_API_KEY=
EMAIL_FROM="SecureChainMarkets <noreply@securechainmarkets.com>"

# ── File uploads (UploadThing) ──────────────────────────────────────
# Leave blank to disable file uploads in dev.
UPLOADTHING_TOKEN=

# ── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development
